# VALLUM — Environment Configuration Template
# COPY THIS FILE TO .env AND FILL WITH YOUR VALUES
# NEVER COMMIT .env — IT IS IGNORED BY GIT

# Environment
ENV=development
DEBUG=false

# Gemini API (Google AI Studio / GCP)
# Get your key at: https://aistudio.google.com/app/apikey
# For production, use GCP Secret Manager instead
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro

# Lobster Trap (Veea)
LOBSTER_TRAP_URL=http://localhost:8080
LOBSTER_TRAP_POLICY=configs/default_policy.yaml

# Database
DATABASE_URL=sqlite:///./vallum.db

# Audit Chain
AUDIT_CHAIN_SECRET=your_audit_chain_secret_here
AUDIT_CHAIN_ALGORITHM=sha256

# GCP (Production Only)
# GCP_PROJECT_ID=your-gcp-project-id
# GCP_SECRET_MANAGER_ENABLED=false
